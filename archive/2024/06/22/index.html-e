           itemprop="image" width="400" height="225"
           referrerpolicy="no-referrer" loading="lazy">
    </div>
    <h3 itemprop="headline">Newly found Assyrian camp supports epic biblical account, expert says</h3>
    <p itemprop="text">
      A long-lost Assyrian military camp recently found by a Near Eastern archaeology scholar may provide insight and corroborate a biblical account.
      <a itemprop="url" href="/world/2024/06/21/newly-found-assyrian-camp-supports-epic-biblical-account-expert-says/"  >(Fox News)</a>
    </p>
  </div>
</div></div><div class="column vcwi"><div itemscope itemtype="https://schema.org/NewsArticle" class="card">
  <meta itemprop="datePublished" content="Fri, 21 Jun 2024 12:49:35 -0400">
  <meta itemprop="dateModified" content="Fri, 21 Jun 2024 12:49:35 -0400">
  <span itemprop="author" itemscope itemtype="https://schema.org/Person">
    <meta itemprop="name" content="Fox News">
