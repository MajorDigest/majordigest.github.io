           itemprop="image" width="400" height="225"
           referrerpolicy="no-referrer" loading="lazy">
    </div>
    <h3 itemprop="headline">Twice-yearly injection fully protects women from HIV, trial finds</h3>
    <p itemprop="text">
      The trial showed the new injection "demonstrated 100% efficacy as a preventive treatment" for HIV among African women.
      <a itemprop="url" href="/world/2024/06/25/twice-yearly-injection-fully-protects-women-from-hiv-trial-finds/"  >(Anna Kutz, WFLA, NBC)</a>
    </p>
  </div>
</div></div><div class="column hcwi"><div itemscope itemtype="https://schema.org/NewsArticle" class="card">
  <meta itemprop="datePublished" content="Mon, 24 Jun 2024 11:58:37 +0000">
  <meta itemprop="dateModified" content="Mon, 24 Jun 2024 11:58:37 +0000">
  <span itemprop="author" itemscope itemtype="https://schema.org/Person">
    <meta itemprop="name" content="The Associated Press, WFLA, NBC">
