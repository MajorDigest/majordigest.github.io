  <meta itemprop="datePublished" content="Sat, 29 Jun 2024 18:15:20 +0000">
  <meta itemprop="dateModified" content="Sat, 29 Jun 2024 18:15:20 +0000">
  <span itemprop="author" itemscope itemtype="https://schema.org/Person">
    <meta itemprop="name" content="Jared Gans, WFLA, NBC">
  </span>
