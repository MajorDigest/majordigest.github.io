           itemprop="image" width="400" height="225"
           referrerpolicy="no-referrer" >
    </div>
    <h3 itemprop="headline">Hackers may have stolen every American's Social Security number: Report</h3>
    <p itemprop="text">
      The theft happened in April, according to a class-action lawsuit filed in federal court in Fort Lauderdale, Florida.
      <a itemprop="url" href="/us/2024/08/15/hackers-grab-every-social-security-number/"  >(Rich Johnson, NewsNation)</a>
    </p>
  </div>
</div><div itemscope itemtype="https://schema.org/NewsArticle" class="card">
  <meta itemprop="datePublished" content="Wed, 14 Aug 2024 14:53:36 +0000">
  <meta itemprop="dateModified" content="Wed, 14 Aug 2024 14:53:36 +0000">
