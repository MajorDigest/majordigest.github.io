  <meta itemprop="datePublished" content="Sun, 18 Aug 2024 18:37:51 +0000">
  <meta itemprop="dateModified" content="Sun, 18 Aug 2024 18:37:51 +0000">
  <span itemprop="author" itemscope itemtype="https://schema.org/Person">
    <meta itemprop="name" content="DAVE CAMPBELL, Associated Press, KGET 17, NBC">
  </span>
  <div class="card-content">
