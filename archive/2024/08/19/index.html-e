</div><div itemscope itemtype="https://schema.org/NewsArticle" class="card">
  <meta itemprop="datePublished" content="Fri, 16 Aug 2024 04:50:30 +0000">
  <meta itemprop="dateModified" content="Fri, 16 Aug 2024 04:50:30 +0000">
  <span itemprop="author" itemscope itemtype="https://schema.org/Person">
    <meta itemprop="name" content="NewsNation">
  </span>
  <div class="card-content">
