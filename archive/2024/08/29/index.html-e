        onerror="this.parentNode.style.display='none'" referrerpolicy="no-referrer" >
    </div>
    <h3 itemprop="headline">Vodou mystery: Man says mom's death certificate lacks details</h3>
    <p itemprop="text">
      Timothy Jackson, Dana Jackson's son, said he hasn't received any answers about his mom's death in two weeks.
      <a itemprop="url" href="/us/2024/08/28/vodou-mystery-man-says-moms-death-certificate-lacks-details/"  >(Liz Jassin, NewsNation)</a>
    </p>
  </div>
</div>
<div itemscope itemtype="https://schema.org/NewsArticle" class="card">
  <meta itemprop="datePublished" content="Wed, 28 Aug 2024 09:55:33 GMT">
  <meta itemprop="dateModified" content="Wed, 28 Aug 2024 09:55:33 GMT">
  <span itemprop="author" itemscope itemtype="https://schema.org/Person">
    <meta itemprop="name" content="JENNIFER SINCO KELLEHER, Associated Press, ABC 4">
