        onerror="this.parentNode.style.display='none'" referrerpolicy="no-referrer" loading="lazy">
    </div>
    <h3 itemprop="headline">Cowboys defensive back Markquese Bell arrested on felony drug charge in Texas</h3>
    <p itemprop="text">
      Dallas Cowboys safety Markquese Bell was arrested by Prosper Police on two drug charges, including felony possession of a controlled substance.
      <a itemprop="url" href="/sports/2026/04/11/cowboys-defensive-back-markquese-bell-arrested-felony-drug-charge-texas/"  >(Fox News)</a>
    </p>
  </div>
</div>
<div itemscope itemtype="https://schema.org/NewsArticle" class="card">
  <meta itemprop="datePublished" content="Sat, 11 Apr 2026 17:22:58 GMT">
  <meta itemprop="dateModified" content="Sat, 11 Apr 2026 17:22:58 GMT">
