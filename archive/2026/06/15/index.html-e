        onerror="this.parentNode.style.display='none'" referrerpolicy="no-referrer" >
    </div>
    <h3 itemprop="headline">California couple fights off 70-pound black bear with hatchet and water bottle outside their home</h3>
    <p itemprop="text">
      A California couple suffered significant injuries after a black bear attacked them outside their Mammoth Lakes home, with the bear later euthanized.
      <a itemprop="url" href="/us/2026/06/14/california-couple-fights-70-pound-black-bear-hatchet-water-bottle-outside-home/"  >(Fox News)</a>
    </p>
  </div>
</div>
<div itemscope itemtype="https://schema.org/NewsArticle" class="card">
  <meta itemprop="datePublished" content="Sat, 13 Jun 2026 14:08:46 GMT">
